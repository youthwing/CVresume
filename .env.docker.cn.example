COMPOSE_PROJECT_NAME=cvresume

MYSQL_IMAGE=m.daocloud.io/docker.io/library/mysql:8.0
NODE_IMAGE=m.daocloud.io/docker.io/library/node:22-bookworm-slim
MAVEN_IMAGE=m.daocloud.io/docker.io/library/maven:3.9.9-eclipse-temurin-21
JAVA_IMAGE=m.daocloud.io/docker.io/library/eclipse-temurin:21-jre-jammy

MYSQL_DATABASE=crseume
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_USERNAME=crseume_user
MYSQL_PASSWORD=change_this_user_password

NEXT_PUBLIC_API_BASE_URL=/api
SKIP_BUILD_VALIDATION=true

FRONTEND_BASE_URL=https://cv.wingod.top
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://cv.wingod.top,http://cv.wingod.top

MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false
AUTH_MAIL_FROM=
AUTH_MAIL_FROM_NAME=CVResume 简历救兵

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
LLM_ENABLED=true
